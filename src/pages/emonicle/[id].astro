---
import { fetchAllEmonicles } from '../../lib/content';
import EmoniclePost from '../../layouts/EmoniclePost.astro';
import { validateIdPost } from '../../utils/validation';
import { isPublished } from '../../utils/date';

export async function getStaticPaths() {
  // 下書き・未来日も含めて全件ページ化（URL直アクセスでプレビュー可能に）。
  const posts = await fetchAllEmonicles();

  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { id } = Astro.params;
const { post } = Astro.props;

// Validate that the ID exists and matches the post
if (!validateIdPost(post, id)) {
  return Astro.redirect('/404');
}

const { Content } = await post.render();

// microCMSのコンテンツはHTMLとして返される
const isMicroCMS = post.source === 'microcms';
const htmlContent = isMicroCMS ? Content() : null;

const preview = Boolean(post.data.draft) || !isPublished(post.data.date);
---

<EmoniclePost post={post} preview={preview}>
  {isMicroCMS ? (
    <div set:html={htmlContent} class="microcms-content" />
  ) : (
    <Content />
  )}
</EmoniclePost>

<style>
  /* microCMSのHTMLコンテンツのスタイリング */
  :global(.microcms-content p) {
    margin-top: 0.5em;
    margin-bottom: 0.5em;
  }

  :global(.microcms-content p:last-child) {
    margin-bottom: 0;
  }

  /* 空の段落も高さを持つようにする */
  :global(.microcms-content p:empty),
  :global(.microcms-content p:has(> br:only-child)) {
    min-height: 1em;
  }

  /* iframely埋め込みの上下マージン */
  :global(.microcms-content .iframely-embed) {
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
  }
</style>