---
import { fetchAllEmonicles } from '../../utils/content-fetcher';
import EmoniclePost from '../../layouts/EmoniclePost.astro';
import { filterPublishedEmonicles } from '../../utils/posts';
import { validateIdPost } from '../../utils/validation';

export async function getStaticPaths() {
  const posts = await fetchAllEmonicles();
  const publishedPosts = filterPublishedEmonicles(posts);

  return publishedPosts.map((post) => ({
    params: { id: post.data.id.toString() },
    props: { post },
  }));
}

const { id } = Astro.params;
const { post } = Astro.props;

// Validate that the ID exists and matches the post
if (!validateIdPost(post, id)) {
  return Astro.redirect('/404');
}

const { Content } = await post.render();

// microCMSのコンテンツはHTMLとして返される
const isMicroCMS = post.source === 'microcms';
const htmlContent = isMicroCMS ? Content() : null;
---

<EmoniclePost post={post}>
  {isMicroCMS ? (
    <div set:html={htmlContent} class="microcms-content" />
  ) : (
    <Content />
  )}
</EmoniclePost>

<style>
  /* microCMSのHTMLコンテンツのスタイリング */
  :global(.microcms-content p) {
    margin-bottom: 1em;
  }

  :global(.microcms-content p:last-child) {
    margin-bottom: 0;
  }

  /* 空の段落も高さを持つようにする */
  :global(.microcms-content p:empty) {
    min-height: 1em;
  }
</style>