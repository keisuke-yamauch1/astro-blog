---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import PodcastPreview from '../../components/PodcastPreview.astro';
import { fetchAllPodcastFeeds } from '../../utils/podcast';

const allFeeds = await fetchAllPodcastFeeds();
---

<BaseLayout title="Podcast" description="ポッドキャスト一覧">
  <div class="mb-8">
    <h1 class="text-4xl font-bold mb-4 text-gray-900 dark:text-white">Podcast</h1>

    <div role="tablist" class="flex border-b border-gray-200 dark:border-gray-700 mb-6">
      {allFeeds.map(({ config }, index) => (
        <button
          role="tab"
          aria-selected={index === 0 ? 'true' : 'false'}
          aria-controls={`panel-${index}`}
          id={`tab-${index}`}
          class:list={[
            'px-4 py-2 text-sm font-medium border-b-2 transition-colors duration-200 cursor-pointer',
            index === 0
              ? 'border-primary-600 text-primary-600 dark:border-primary-400 dark:text-primary-400'
              : 'border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 hover:border-gray-300 dark:hover:border-gray-600',
          ]}
          data-tab-index={index}
        >
          {config.label}
        </button>
      ))}
    </div>

    {allFeeds.map(({ config, feed }, index) => (
      <div
        role="tabpanel"
        id={`panel-${index}`}
        aria-labelledby={`tab-${index}`}
        class={index !== 0 ? 'hidden' : ''}
      >
        <div class="flex items-start gap-4 p-4 bg-gray-50 dark:bg-gray-800/60 rounded-xl border border-gray-200 dark:border-gray-700 mb-6">
          {feed.channel.image && (
            <img
              src={feed.channel.image}
              alt={feed.channel.title}
              class="w-24 h-24 rounded-lg object-cover"
            />
          )}
          <div>
            <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">
              {feed.channel.title}
            </h2>
            <p class="text-gray-600 dark:text-gray-300 text-sm">
              {feed.channel.description}
            </p>
            <a
              href={feed.channel.link}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center mt-2 text-primary-600 dark:text-primary-400 hover:underline text-sm"
            >
              {config.linkText}
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-4 w-4 ml-1"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                />
              </svg>
            </a>
          </div>
        </div>

        <section class="flex flex-col gap-6">
          {feed.episodes.map((episode) => (
            <PodcastPreview episode={episode} linkText={config.linkText} />
          ))}
        </section>
      </div>
    ))}
  </div>

  <script>
    const tabs = document.querySelectorAll<HTMLButtonElement>('[role="tab"]');
    const panels = document.querySelectorAll<HTMLDivElement>('[role="tabpanel"]');

    const activeClasses = 'border-primary-600 text-primary-600 dark:border-primary-400 dark:text-primary-400';
    const inactiveClasses = 'border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 hover:border-gray-300 dark:hover:border-gray-600';

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const index = tab.dataset.tabIndex;

        tabs.forEach((t) => {
          t.setAttribute('aria-selected', 'false');
          activeClasses.split(' ').forEach((c) => t.classList.remove(c));
          inactiveClasses.split(' ').forEach((c) => t.classList.add(c));
        });

        tab.setAttribute('aria-selected', 'true');
        inactiveClasses.split(' ').forEach((c) => tab.classList.remove(c));
        activeClasses.split(' ').forEach((c) => tab.classList.add(c));

        panels.forEach((panel) => {
          panel.classList.add('hidden');
        });

        const targetPanel = document.getElementById(`panel-${index}`);
        if (targetPanel) {
          targetPanel.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
