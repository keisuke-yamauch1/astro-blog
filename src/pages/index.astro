---
import BaseLayout from '../layouts/BaseLayout.astro'
import BlogPreview from '../components/BlogPreview.astro'
import DiaryPreview from '../components/DiaryPreview.astro'
import SocialLinks from '../components/SocialLinks.astro'
import { getEntry } from 'astro:content'
import { fetchAllBlogs, fetchAllDiaries } from '../utils/content-fetcher'
import { filterPosts, filterDiaries } from '../utils/posts'
import { siteConfig } from '../config'

const [posts, diaryEntries, homeContent] = await Promise.all([
  fetchAllBlogs(),
  fetchAllDiaries(),
  getEntry('home', 'index'),
]);

const { Content: HomeContent } = homeContent ? await homeContent.render() : { Content: null };

// Configure homepage post filtering
const homePagePosts = filterPosts(posts, {
  ...siteConfig.homepage,
})

// Get latest diary entries
const latestDiaryEntries = filterDiaries(diaryEntries, {
  maxEntries: 5
})
---

<BaseLayout title={siteConfig.title}>
  <div class="text-left mb-8">
    <h1 class="text-2xl font-bold mb-4 text-gray-900 dark:text-white">{siteConfig.slogan}</h1>
    <SocialLinks />
    <!-- <p class="text-xl mb-8 text-gray-600 dark:text-gray-300">{siteConfig.description}</p> -->
  </div>

  {HomeContent && (
    <div class="prose dark:prose-invert max-w-none mb-12">
      <HomeContent />
    </div>
  )}

  <!-- <div class="space-y-16">
    <section>
      <h2 class="text-2xl font-bold mb-6 text-gray-900 dark:text-white">最新の日記</h2>
      <div class="space-y-8">
        {latestDiaryEntries.map((entry) => <DiaryPreview entry={entry} />)}
      </div>
      <div class="mt-4 text-right">
        <a href="/diary/" class="text-primary-500 hover:text-primary-600 text-sm">もっとみる →</a>
      </div>
    </section>

    <section>
      <h2 class="text-2xl font-bold mb-6 text-gray-900 dark:text-white">最新のブログ</h2>
