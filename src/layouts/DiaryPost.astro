---
import BaseLayout from './BaseLayout.astro'
import ArticleContent from '../components/ArticleContent.astro';
import type { UnifiedDiaryEntry } from '../lib/content'
import { formatDate } from '../utils/date';

interface Props {
  entry: UnifiedDiaryEntry
  preview?: boolean
}

const { entry, preview = false } = Astro.props
const { title, description, date, weather, condition, image } = entry.data
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<BaseLayout title={title} description={description} image={image} ogType="article" noindex={preview}>
  <article class="max-w-3xl mx-auto px-4">
    {preview && (
      <div class="mb-6 rounded-lg border border-amber-400 bg-amber-50 dark:bg-amber-900/20 px-4 py-2 text-sm text-amber-700 dark:text-amber-300">
        下書きプレビュー — このページは一覧・RSS・検索には表示されません
      </div>
    )}
    {image && <img src={image} alt={title} class="w-full h-[400px] object-cover rounded-xl shadow-lg mb-8" loading="eager" />}
    <header class="mb-12">
      <h1 class="text-3xl md:text-4xl font-bold mb-4 text-gray-900 dark:text-gray-100">
        {title}
      </h1>
      <div class="flex flex-col sm:flex-row gap-2 sm:gap-6 text-gray-600 dark:text-gray-300">
        <div class="flex items-center">
          <span class="font-semibold mr-2 min-w-[2.5em]">日付:</span>
          <span>{formatDate(date)}</span>
        </div>
        {weather && <div class="flex items-center">
          <span class="font-semibold mr-2 min-w-[2.5em]">天気:</span>
          <span>{weather}</span>
        </div>}
        {condition && <div class="flex items-center">
          <span class="font-semibold mr-2 min-w-[2.5em]">調子:</span>
          <span>{condition}</span>
        </div>}
      </div>
    </header>
    <ArticleContent class="diary-content" url={canonicalURL.href} title={title}>
      <slot />
    </ArticleContent>
  </article>
</BaseLayout>

<style>
  /* ネストしたulの上下マージンを除去（日記専用） */
  :global(.diary-content .prose li ul) {
    margin-top: 0;
    margin-bottom: 0;
  }

  :global(.diary-content .prose li ol) {
    margin-top: 0;
    margin-bottom: 0;
  }
</style>
