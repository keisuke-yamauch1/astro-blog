---
import BaseLayout from './BaseLayout.astro'
import PostDate from '../components/PostDate.astro'
import ArticleContent from '../components/ArticleContent.astro';
import type { UnifiedEmonicleEntry } from '../lib/content'

interface Props {
  post: UnifiedEmonicleEntry
  preview?: boolean
}

const { post, preview = false } = Astro.props

// Safety check for post and post.data
if (!post || !post.data) {
  throw new Error('Post or post.data is undefined in EmoniclePost layout');
}

const { title, date, image } = post.data
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<BaseLayout title={title} description={post.data.description} image={image} ogType="article" noindex={preview}>
  <article class="max-w-3xl mx-auto px-4">
    {preview && (
      <div class="mb-6 rounded-lg border border-amber-400 bg-amber-50 dark:bg-amber-900/20 px-4 py-2 text-sm text-amber-700 dark:text-amber-300">
        下書きプレビュー — このページは一覧・RSS・検索には表示されません
      </div>
    )}
    {image && <img src={image} alt={title} class="w-full h-[400px] object-cover rounded-xl shadow-lg mb-8" loading="eager" />}
    <header class="mb-12">
      <h1 class="text-3xl md:text-4xl font-bold mb-4 text-gray-900 dark:text-gray-100">
        {title}
      </h1>
      <div class="mb-6">
        <PostDate date={date} />
      </div>
    </header>
    <ArticleContent url={canonicalURL.href} title={title}>
      <slot />
    </ArticleContent>
  </article>
</BaseLayout>