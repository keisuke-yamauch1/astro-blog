---
import type { UnifiedDiaryEntry } from '../lib/microcms';
import PreviewCard from './PreviewCard.astro';
import { formatDate, getDiaryPath } from '../utils/date';

interface Props {
  entry: UnifiedDiaryEntry;
}

const { entry } = Astro.props;
const { title, description, date, weather, condition, image } = entry.data;
---

<PreviewCard href={getDiaryPath(date)} title={title} image={image} showMarginBottom={false}>
  {description && <p slot="content" class="text-gray-800 dark:text-gray-200 mb-4">{description}</p>}
  <div slot="content" class="flex flex-col gap-2 text-sm text-gray-600 dark:text-gray-300">
    <div>日付：{formatDate(date)}</div>
    {weather && <div>天気：{weather}</div>}
    {condition && <div>調子：{condition}</div>}
  </div>
</PreviewCard>
