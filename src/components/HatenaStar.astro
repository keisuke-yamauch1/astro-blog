---
// はてなスターのアバター表示モード用のコンポーネント
// 新しいstar.jsスクリプトを使用して、data属性で設定を行います
---

<!-- はてなスターのコンテナ（data属性で設定） -->
<div
  class="hatena-star-container my-4"
  data-hatena-star-container
  data-hatena-star-variant="profile-icon">
  <span data-hatena-star=""></span>
</div>

<!-- 新しいはてなスタースクリプト -->
<script type="text/javascript" src="https://s.hatena.ne.jp/js/widget/star.js"></script>

<!-- URLとタイトルを動的に設定するスクリプト -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.querySelector('[data-hatena-star-container]');
    const postUrl = document.querySelector('.post-url');
    const titleEl = document.querySelector('h1');

    if (container && postUrl && titleEl) {
      // ページのURLとタイトルをdata属性に設定
      const url = postUrl.href || postUrl.getAttribute('href') || window.location.href;
      const title = titleEl.textContent?.trim() || document.title;

      container.setAttribute('data-hatena-star-url', url);
      container.setAttribute('data-hatena-star-title', title);
    }
  });
</script>
